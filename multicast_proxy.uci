# UCI配置: /etc/config/multicast_proxy
# multicast_proxy - All-in-One IPTV Proxy

config proxy 'main'
    option enabled '1'
    option port '8888'
    option upstream 'eth0.2'
    option max_clients '100'
    option timeout '0'
    option ssm_source ''
    option verbose '0'
    # 嗅探模式 (自动发现IPTV频道)
    option sniff_mode '0'
    # 嗅探接口 (默认使用upstream接口)
    option mcast_iface ''
